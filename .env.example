# LinkedIn session cookie — grab from browser DevTools > Application > Cookies > li_at
LINKEDIN_LI_AT=

# Slack Incoming Webhook URL — create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# (Optional) Directory for persistent data storage (seen-connections.json).
# On Railway, set this to a volume mount path (e.g. /data).
# Defaults to ./data relative to the project root.
DATA_DIR=
