# Admin API password — required for /admin/* endpoints
ADMIN_PASSWORD=

# Anthropic API key — for AI-generated outreach DM suggestions
ANTHROPIC_API_KEY=

# Slack Bot Token — required for edit modal (xoxb-...)
SLACK_BOT_TOKEN=

# (Optional) Directory for persistent data storage (DB + seen-connections files).
# On Railway, set this to a volume mount path (e.g. /data).
# Defaults to ./data relative to the project root.
DATA_DIR=

# --- Legacy single-tenant mode (optional) ---
# If set, these will run alongside any DB clients.
# For multi-tenant, add clients via the admin API instead.
LINKEDIN_LI_AT=
SLACK_WEBHOOK_URL=
